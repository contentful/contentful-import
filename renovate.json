{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeRequireAllStatusChecks",
    ":automergeAll"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 15,
  "semanticCommits": "enabled",
  "semanticCommitType": "build",
  "minimumReleaseAge": "15 days",
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Enable npm updates",
      "matchCategories": ["npm"],
      "enabled": true
    },
    {
      "description": "Pin Node.js and @types/node to 18.x",
      "matchPackageNames": ["node", "@types/node"],
      "allowedVersions": "^18",
      "automerge": false
    },
    {
      "description": "Group production dependencies, use deps scope",
      "matchDepTypes": ["dependencies"],
      "semanticCommitScope": "deps",
      "groupName": "production dependencies"
    },
    {
      "description": "Group dev dependencies, use deps-dev scope",
      "matchDepTypes": ["devDependencies"],
      "semanticCommitScope": "deps-dev",
      "groupName": "dev dependencies"
    },
    {
      "description": "Group GitHub Actions, use gha scope and pin to SHA",
      "matchManagers": ["github-actions"],
      "semanticCommitScope": "gha",
      "pinDigests": true,
      "groupName": "github-actions"
    }
  ]
}